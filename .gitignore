# CRLM dormancy project gitignore

# ----------------------------------------------------------------------
# macOS / editor / IDE files
# ----------------------------------------------------------------------
.DS_Store
.Spotlight-V100/
.Trashes/
.Rproj.user/
.vscode/.ropeproject/
.idea/

# ----------------------------------------------------------------------
# R / Python runtime files
# ----------------------------------------------------------------------
.Rhistory
.RData
.Ruserdata
renv/.cache/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# ----------------------------------------------------------------------
# Logs, temporary files and LaTeX intermediates
# ----------------------------------------------------------------------
*.log
*.tmp
*.temp
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb

# ----------------------------------------------------------------------
# Large local omics files and local reference/cache resources
# ----------------------------------------------------------------------
*.fastq
*.fq
*.fastq.gz
*.fq.gz
*.bam
*.sam
*.cram
*.bai
*.crai
data/**

# ----------------------------------------------------------------------
# Generated Beamer TeX files
# ----------------------------------------------------------------------
# These TeX files are generated by scripts/beamer/build and should not be
# committed. Keep only the build scripts and reusable generator code in Git.
scripts/beamer/beamer_report.tex
scripts/beamer/sections/
scripts/beamer/generated_tables/

# ----------------------------------------------------------------------
# Analysis outputs and intermediate files
# ----------------------------------------------------------------------
# All tables, plots, reports, LaTeX build products, logs and qs2 caches are
# reproducible from the analysis/build scripts.
results/**
temporary/**
omnipathr-log/
omipathr-log/
manuscripts/

# ----------------------------------------------------------------------
# Keep explicit placeholder files if they are ever needed for empty folders
# ----------------------------------------------------------------------
!**/.keep
